# Local machine overrides for this repo.
# Copy this file to .env and adjust the path for your workstation.

GODOT4_BIN=C:\Tools\Godot\Godot_v4.6.1-stable_win64.exe
# Optional: force the godot-cpp API target used during configure/build.
# If omitted, the configure script tries to infer it from GODOT4_BIN and
# finally falls back to compatibility_minimum from the .gdextension file.
# GODOT_API_VERSION=4.6
