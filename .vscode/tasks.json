{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure preset",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\configure-gcc-preset.ps1",
        "-Preset",
        "${input:cmakePreset}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build preset",
      "type": "shell",
      "dependsOn": "CMake: Configure preset",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "${input:cmakePreset}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CMake: Build windows-debug",
      "type": "shell",
      "dependsOn": "CMake: Configure windows-debug",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "windows-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CMake: Build windows-release",
      "type": "shell",
      "dependsOn": "CMake: Configure windows-release",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "windows-release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CMake: Configure windows-debug",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\configure-gcc-preset.ps1",
        "-Preset",
        "windows-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Configure windows-release",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\configure-gcc-preset.ps1",
        "-Preset",
        "windows-release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "cmakePreset",
      "type": "pickString",
      "description": "Choose a CMake preset",
      "options": [
        "windows-debug",
        "windows-release"
      ],
      "default": "windows-debug"
    }
  ]
}
