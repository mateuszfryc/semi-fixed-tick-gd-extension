{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Cargo: Build semi_fixed_tick debug",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "--manifest-path",
        "${workspaceFolder}\\addons\\semi_fixed_tick\\Cargo.toml"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "Cargo: Sync semi_fixed_tick debug",
      "type": "shell",
      "dependsOn": "Cargo: Build semi_fixed_tick debug",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\sync-rust-addon-binaries.ps1",
        "-Profile",
        "debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Cargo: Build semi_fixed_tick release",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "--release",
        "--manifest-path",
        "${workspaceFolder}\\addons\\semi_fixed_tick\\Cargo.toml"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "Cargo: Sync semi_fixed_tick release",
      "type": "shell",
      "dependsOn": "Cargo: Build semi_fixed_tick release",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\sync-rust-addon-binaries.ps1",
        "-Profile",
        "release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Godot: Launch local project (semi_fixed_tick debug)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\run-godot-project.ps1",
        "-ProjectPath",
        "${workspaceFolder}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Cargo: Sync semi_fixed_tick debug",
      "problemMatcher": []
    },
    {
      "label": "Godot: Launch local project (semi_fixed_tick release)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\run-godot-project.ps1",
        "-ProjectPath",
        "${workspaceFolder}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Cargo: Sync semi_fixed_tick release",
      "problemMatcher": []
    }
  ]
}
